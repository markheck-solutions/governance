{
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "decision",
    "base_sha",
    "claimed_base_sha",
    "head_sha",
    "evaluator_sha",
    "claimed_evaluator_sha",
    "checkout_head_sha",
    "lock_sha256",
    "python_version",
    "platform_system",
    "platform_machine",
    "runtime_root",
    "python_path",
    "ruff_module_origin",
    "ruff_executable",
    "packages",
    "commands",
    "error",
    "payload_sha256"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "status": {"type": "string", "enum": ["PASS", "FAIL"]},
    "decision": {"type": "string", "enum": ["TOOLCHAIN_READY", "BLOCK_TECHNICAL"]},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "claimed_base_sha": {"type": "string", "maxLength": 200},
    "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "evaluator_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "claimed_evaluator_sha": {"type": "string", "maxLength": 200},
    "checkout_head_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "lock_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "python_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "platform_system": {"type": "string", "minLength": 1},
    "platform_machine": {"type": "string", "minLength": 1},
    "runtime_root": {"type": "string", "minLength": 1},
    "python_path": {"type": ["string", "null"], "minLength": 1},
    "ruff_module_origin": {"type": ["string", "null"], "minLength": 1},
    "ruff_executable": {"type": ["string", "null"], "minLength": 1},
    "packages": {
      "type": "array",
      "minItems": 0,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "version"],
        "properties": {
          "name": {"type": "string", "enum": ["ruff"]},
          "version": {"type": "string", "enum": ["0.15.21"]}
        },
        "additionalProperties": false
      }
    },
    "commands": {
      "type": "array",
      "minItems": 0,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "command",
          "started_at",
          "completed_at",
          "timeout_seconds",
          "timed_out",
          "exit_code"
        ],
        "properties": {
          "command": {
            "type": "array",
            "minItems": 1,
            "maxItems": 32,
            "items": {"type": "string", "minLength": 1}
          },
          "started_at": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
          },
          "completed_at": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
          },
          "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 120},
          "timed_out": {"type": "boolean"},
          "exit_code": {"type": ["integer", "null"]}
        },
        "additionalProperties": false
      }
    },
    "error": {"type": ["string", "null"], "minLength": 1, "maxLength": 4096},
    "payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
