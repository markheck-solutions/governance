{
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "adapter",
    "repository_url",
    "repository_identity",
    "language_runtime",
    "production_roots",
    "test_roots",
    "source_globs",
    "ignore_globs",
    "immutable_revisions",
    "revision_modes",
    "checkout_commands",
    "setup_commands",
    "behavior_cases",
    "structural_detectors",
    "detector_policies",
    "gate_contract",
    "target_specific_exclusions",
    "expected_artifact_fields",
    "supported_operating_systems",
    "runtime_prerequisites"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "adapter": {
      "type": "string",
      "enum": ["raw", "python", "node", "dotnet", "go", "rust", "java", "powershell"]
    },
    "repository_url": { "type": "string", "minLength": 1 },
    "repository_identity": {
      "type": "object",
      "required": ["canonical_url"],
      "properties": {
        "canonical_url": { "type": "string", "minLength": 1 },
        "owner": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "language_runtime": { "type": "string", "minLength": 1 },
    "production_roots": { "type": "array", "items": { "type": "string" } },
    "test_roots": { "type": "array", "items": { "type": "string" } },
    "source_globs": { "type": "array", "items": { "type": "string" } },
    "ignore_globs": { "type": "array", "items": { "type": "string" } },
    "immutable_revisions": {
      "type": "object",
      "required": ["base_sha", "head_sha"],
      "properties": {
        "base_sha": { "type": "string", "minLength": 40 },
        "head_sha": { "type": "string", "minLength": 40 },
        "merge_sha": { "type": ["string", "null"] },
        "safe_base_sha": { "type": ["string", "null"] },
        "safe_head_sha": { "type": ["string", "null"] }
      }
    },
    "revision_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["HISTORICAL_FIXED", "SAFE_FIXED", "CANDIDATE_DYNAMIC"]
      }
    },
    "checkout_commands": { "type": "array", "items": { "type": "string" } },
    "setup_commands": { "type": "array", "items": { "type": "string" } },
    "build_setup_commands": { "type": "array", "items": { "type": "string" } },
    "behavior_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "provenance_classification",
          "reproducer",
          "source_files",
          "source_symbols",
          "expected_source_hashes"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "pull_request": { "type": ["integer", "null"] },
          "revision_modes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["HISTORICAL_FIXED", "SAFE_FIXED", "CANDIDATE_DYNAMIC"]
            }
          },
          "behavior_comparison_policy": {
            "type": "string",
            "enum": ["PINNED_EXPECTED", "PRESERVE_BASE_BEHAVIOR", "BUSINESS_REVIEW_ON_CHANGE"]
          },
          "comparison_policies": { "type": "object" },
          "provenance_classification": {
            "type": "string",
            "enum": ["EXECUTES_PINNED_TARGET_CODE", "EXECUTES_EXTRACTED_REPRODUCER", "FIXTURE_ONLY"]
          },
          "classification_reason": { "type": "string" },
          "required_behavior_evidence": { "type": "boolean" },
          "reproducer": { "type": "string", "minLength": 1 },
          "timeout_seconds": { "type": "integer", "minimum": 1 },
          "source_files": { "type": "array", "items": { "type": "string" } },
          "source_symbols": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "symbol"],
              "properties": {
                "path": { "type": "string" },
                "symbol": { "type": "string" }
              }
            }
          },
          "expected_base_result": { "type": "object" },
          "expected_source_hashes": { "type": "object" }
        }
      }
    },
    "structural_detectors": { "type": "array", "items": { "type": "string" } },
    "detector_policies": {
      "type": "object"
    },
    "gate_contract": {
      "type": "object",
      "properties": {
        "required_files": { "type": "array", "items": { "type": "string" } },
        "required_commands": { "type": "array", "items": { "type": "string" } },
        "approved_reusable_workflows": { "type": "array", "items": { "type": "string" } },
        "governed_roots": { "type": "array", "items": { "type": "string" } },
        "known_debt": { "type": "array", "items": { "type": "string" } }
      }
    },
    "target_specific_exclusions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "justification"],
        "properties": {
          "path": { "type": "string" },
          "justification": { "type": "string", "minLength": 1 }
        }
      }
    },
    "expected_artifact_fields": { "type": "array", "items": { "type": "string" } },
    "supported_operating_systems": { "type": "array", "items": { "type": "string" } },
    "runtime_prerequisites": { "type": "array", "items": { "type": "string" } }
  }
}
