{
  "type": "object",
  "required": [
    "schema_version",
    "repository",
    "repository_id",
    "head_repository_id",
    "event_name",
    "pull_request_number",
    "base_sha",
    "head_sha",
    "workflow_ref",
    "workflow_sha",
    "run_id",
    "run_attempt",
    "expected_artifact_name",
    "artifact_id",
    "artifact_name",
    "artifact_url",
    "artifact_digest",
    "receipt_file_sha256",
    "receipt_payload_sha256",
    "payload_sha256"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
    "repository_id": {"type": "string", "pattern": "^[1-9][0-9]{0,19}$"},
    "head_repository_id": {"type": "string", "pattern": "^[1-9][0-9]{0,19}$"},
    "event_name": {"type": "string", "enum": ["pull_request"]},
    "pull_request_number": {"type": "integer", "minimum": 1},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "workflow_ref": {"type": "string", "pattern": "^[^\\r\\n]{1,500}$"},
    "workflow_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "run_id": {"type": "string", "pattern": "^[1-9][0-9]{0,19}$"},
    "run_attempt": {"type": "string", "pattern": "^[1-9][0-9]{0,19}$"},
    "expected_artifact_name": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,120}$"},
    "artifact_id": {"type": "string", "pattern": "^[1-9][0-9]{0,19}$"},
    "artifact_name": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,120}$"},
    "artifact_url": {"type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/actions/runs/[1-9][0-9]{0,19}/artifacts/[1-9][0-9]{0,19}$"},
    "artifact_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "receipt_file_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "receipt_payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "payload_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
