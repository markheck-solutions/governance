    "enforcement_mode": { "type": "string", "enum": ["NON_BLOCKING"] },
    "real_target_shadow_decision": {
      "type": "string",
      "enum": ["SHADOW_MERGE", "SHADOW_BLOCK_TECHNICAL", "SHADOW_ASK_BUSINESS"]
