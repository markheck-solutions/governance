    "revision_validation": {
      "type": "object",
      "required": ["status", "mode", "base_commit_exists", "head_commit_exists", "candidate_pull_request_validation"],
      "properties": {
        "status": { "type": "string", "enum": ["PASS", "FAIL"] },
        "mode": { "type": "string" },
