{
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "owner_status",
    "enforcement_mode",
    "gate_implementation",
    "repo_architecture_supportability",
    "architecture_behavior_proof",
    "base_sha",
    "head_sha",
    "violations",
    "new_violations",
    "existing_violations",
    "resolved_violations",
    "exceptions_applied",
    "expired_exceptions",
    "behavior_fixtures",
    "rule_results",
    "errors"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "owner_status": {"type": "string", "enum": ["GREEN", "RED"]},
    "enforcement_mode": {"type": "string", "enum": ["block_all"]},
    "gate_implementation": {"type": "string", "enum": ["PASS", "FAIL"]},
    "repo_architecture_supportability": {"type": "string", "enum": ["PASS", "FAIL"]},
    "architecture_behavior_proof": {"type": "string", "enum": ["PASS", "FAIL"]},
    "base_sha": {"type": "string", "minLength": 40, "maxLength": 40, "pattern": "^[0-9a-f]{40}$"},
    "head_sha": {"type": "string", "minLength": 40, "maxLength": 40, "pattern": "^[0-9a-f]{40}$"},
    "changed_files": {"type": "array", "items": {"type": "string"}},
    "violations": {"type": "array", "items": {"type": "object"}},
    "new_violations": {"type": "array", "items": {"type": "object"}},
    "existing_violations": {"type": "array", "items": {"type": "object"}},
    "resolved_violations": {"type": "array", "items": {"type": "object"}},
    "exceptions_applied": {"type": "array", "items": {"type": "object"}},
    "expired_exceptions": {"type": "array", "items": {"type": "object"}},
    "behavior_fixtures": {"type": "array", "items": {"type": "object"}},
    "rule_results": {"type": "object"},
    "errors": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
