{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/governance/schemas/v1/review_quorum.schema.json",
  "title": "Fallback clean-room review quorum",
  "type": "object",
  "required": [
    "schema_version",
    "review_gate",
    "github_review_state",
    "reviewed_base_sha",
    "reviewed_head_sha",
    "reviewers"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "review_gate": { "type": "string", "enum": ["FALLBACK_CLEAN_ROOM_QUORUM"] },
    "github_review_state": { "type": "string", "enum": ["STALE", "UNAVAILABLE"] },
    "reviewed_base_sha": { "type": "string", "minLength": 40 },
    "reviewed_head_sha": { "type": "string", "minLength": 40 },
    "github_review_history": { "type": "array", "items": { "type": "object" } },
    "workflow_evidence": { "type": "array", "items": { "type": "object" } },
    "benchmark_artifacts": { "type": "array", "items": { "type": "object" } },
    "unresolved_threads": { "type": "array", "items": { "type": "object" } },
    "reviewers": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "reviewer_id",
          "reviewed_base_sha",
          "reviewed_head_sha",
          "reviewed_files",
          "findings",
          "commands",
          "final_verdict"
        ],
        "properties": {
          "reviewer_id": { "type": "string", "minLength": 1 },
          "reviewed_base_sha": { "type": "string", "minLength": 40 },
          "reviewed_head_sha": { "type": "string", "minLength": 40 },
          "reviewed_files": { "type": "array", "items": { "type": "string" } },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "severity", "message", "has_reproducer"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
                "message": { "type": "string" },
                "has_reproducer": { "type": "boolean" },
                "commands": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "commands": { "type": "array", "items": { "type": "string" } },
          "final_verdict": { "type": "string", "enum": ["CLEAN", "BLOCKING_FINDINGS_PRESENT"] }
        }
      }
    }
  },
  "additionalProperties": false
}
