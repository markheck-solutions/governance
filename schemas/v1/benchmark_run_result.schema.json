{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/governance/schemas/v1/benchmark_run_result.schema.json",
  "title": "Benchmark run result",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "governance_repository_url",
    "governance_evaluator_git_sha",
    "governance_target_pack_hash",
    "schema_hashes",
    "dependency_lock_hash",
    "target_repository_url",
    "target_pr_number",
    "target_base_sha",
    "target_head_sha",
    "target_merge_sha",
    "revision_mode",
    "exact_commands",
    "operating_system",
    "runner_os",
    "python_version",
    "review_gate",
    "github_review_state",
    "github_artifact_id",
    "github_artifact_digest",
    "deterministic_evidence_hash",
    "duration_seconds",
    "repeat_count",
    "phase1_decision",
    "acceptance_errors",
    "target_lock",
    "target_locks",
    "registered_target_evaluations",
    "metrics",
    "cases",
    "artifact_content_hash"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "run_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "governance_repository_url": {"type": "string", "minLength": 1},
    "governance_evaluator_git_sha": {"type": "string", "minLength": 40},
    "governance_target_pack_hash": {"type": "string", "minLength": 64},
    "schema_hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 64}
    },
    "dependency_lock_hash": {"type": "string", "minLength": 64},
    "target_repository_url": {"type": "string", "minLength": 1},
    "target_pr_number": {"type": "integer"},
    "target_base_sha": {"type": "string", "minLength": 40},
    "target_head_sha": {"type": "string", "minLength": 40},
    "target_merge_sha": {"type": "string", "minLength": 40},
    "revision_mode": {"type": "string", "enum": ["HISTORICAL_FIXED"]},
    "exact_commands": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "operating_system": {"type": "string", "minLength": 1},
    "runner_os": {"type": "string", "minLength": 1},
    "python_version": {"type": "string", "minLength": 1},
    "review_gate": {"type": "string", "enum": ["NOT_APPLICABLE"]},
    "github_review_state": {"type": "string", "enum": ["NOT_APPLICABLE"]},
    "github_artifact_id": {"type": ["string", "null"]},
    "github_artifact_digest": {"type": ["string", "null"]},
    "deterministic_evidence_hash": {"type": "string", "minLength": 64},
    "duration_seconds": {"type": "number", "minimum": 0},
    "repeat_count": {"type": "integer", "minimum": 1},
    "phase1_decision": {"type": "string", "enum": ["BENCHMARK_PASS", "BENCHMARK_FAIL"]},
    "acceptance_errors": {"type": "array", "items": {"type": "string"}},
    "artifact_content_hash": {"type": "string", "minLength": 64},
    "target_lock": {
      "type": "object",
      "required": [
        "target_id",
        "repository_url",
        "generated_at",
        "evidence_source",
        "revisions",
        "metadata"
      ],
      "properties": {
        "target_id": {"type": "string", "minLength": 1},
        "repository_url": {"type": "string", "minLength": 1},
        "generated_at": {"type": "string", "minLength": 1},
        "evidence_source": {"type": "string", "minLength": 1},
        "revisions": {"type": "object", "minProperties": 2},
        "metadata": {"type": "object"}
      },
      "additionalProperties": false
    },
    "target_locks": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "object"}
    },
    "registered_target_evaluations": {"type": ["object", "null"]},
    "metrics": {
      "type": "object",
      "required": [
        "critical_defect_recall",
        "critical_defects_blocked",
        "negative_control_recall",
        "negative_controls_blocked",
        "false_block_rate",
        "false_blocks",
        "repeated_run_decision_stability",
        "deterministic_flake_rate",
        "execution_duration_seconds",
        "case_count",
        "critical_defect_count",
        "negative_control_count",
        "verified_safe_count"
      ],
      "properties": {
        "critical_defect_recall": {"type": "number", "minimum": 0, "maximum": 1},
        "critical_defects_blocked": {"type": "integer", "minimum": 0},
        "negative_control_recall": {"type": "number", "minimum": 0, "maximum": 1},
        "negative_controls_blocked": {"type": "integer", "minimum": 0},
        "false_block_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "false_blocks": {"type": "integer", "minimum": 0},
        "repeated_run_decision_stability": {"type": "number", "minimum": 0, "maximum": 1},
        "deterministic_flake_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "execution_duration_seconds": {"type": "number", "minimum": 0},
        "case_count": {"type": "integer", "minimum": 1},
        "critical_defect_count": {"type": "integer", "minimum": 1},
        "negative_control_count": {"type": "integer", "minimum": 1},
        "verified_safe_count": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "category", "label", "critical", "expected_decision", "decision", "evidence"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "label": {"type": "string", "enum": ["REPRODUCED_BAD", "VERIFIED_SAFE", "UNKNOWN"]},
          "critical": {"type": "boolean"},
          "expected_decision": {"type": "string", "enum": ["MERGE", "BLOCK_TECHNICAL", "ASK_BUSINESS"]},
          "decision": {
            "type": "object",
            "required": ["case_id", "decision", "reasons", "evidence_refs", "fail_closed"],
            "properties": {
              "case_id": {"type": "string", "minLength": 1},
              "decision": {"type": "string", "enum": ["MERGE", "BLOCK_TECHNICAL", "ASK_BUSINESS"]},
              "reasons": {"type": "array", "items": {"type": "string"}},
              "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
              "fail_closed": {"type": "boolean"}
            },
            "additionalProperties": false
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["evidence_id", "case_id", "detector_id", "status", "message", "observed", "findings"],
              "properties": {
                "evidence_id": {"type": "string", "minLength": 1},
                "case_id": {"type": "string", "minLength": 1},
                "detector_id": {"type": "string", "minLength": 1},
                "status": {
                  "type": "string",
                  "enum": ["PASS", "FAIL", "UNKNOWN", "MALFORMED", "UNVERIFIABLE", "BUSINESS_AMBIGUITY"]
                },
                "message": {"type": "string"},
                "observed": {"type": "object"},
                "findings": {"type": "array", "items": {"type": "object"}}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
