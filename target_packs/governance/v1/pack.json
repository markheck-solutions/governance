{
  "schema_version": "1.1",
  "id": "governance-v1",
  "adapter": "python",
  "repository_url": "https://github.com/markheck-solutions/governance.git",
  "repository_identity": {
    "canonical_url": "https://github.com/markheck-solutions/governance.git",
    "owner": "markheck-solutions",
    "name": "governance"
  },
  "language_runtime": "python>=3.12",
  "production_roots": ["governance_eval"],
  "test_roots": ["tests"],
  "source_globs": ["**/*.py"],
  "ignore_globs": ["build/**", "dist/**", ".venv/**", "venv/**"],
  "immutable_revisions": {
    "base_sha": "0000000000000000000000000000000000000000",
    "head_sha": "0000000000000000000000000000000000000000",
    "safe_base_sha": "0000000000000000000000000000000000000000",
    "safe_head_sha": "0000000000000000000000000000000000000000"
  },
  "revision_modes": ["HISTORICAL_FIXED", "SAFE_FIXED", "CANDIDATE_DYNAMIC"],
  "checkout_commands": [
    "git clone --no-checkout https://github.com/markheck-solutions/governance.git",
    "git checkout <full-sha>"
  ],
  "setup_commands": [],
  "build_setup_commands": [],
  "behavior_cases": [
    {
      "id": "GOVERNANCE-DETERMINISTIC-MERGE",
      "title": "Clean complete evidence produces the deterministic merge decision",
      "pull_request": null,
      "revision_modes": ["HISTORICAL_FIXED", "SAFE_FIXED", "CANDIDATE_DYNAMIC"],
      "behavior_comparison_policy": "PINNED_EXPECTED",
      "comparison_policies": {
        "HISTORICAL_FIXED": "PINNED_EXPECTED",
        "SAFE_FIXED": "PINNED_EXPECTED",
        "CANDIDATE_DYNAMIC": "PRESERVE_BASE_BEHAVIOR"
      },
      "provenance_classification": "EXECUTES_PINNED_TARGET_CODE",
      "classification_reason": "The governance-owned reproducer imports and executes decide from the exact Governance checkout.",
      "reproducer": "target_packs/governance/v1/reproducer.py",
      "timeout_seconds": 30,
      "source_files": ["governance_eval/decision.py"],
      "source_symbols": [{"path": "governance_eval/decision.py", "symbol": "decide"}],
      "expected_base_result": {"decision": "MERGE", "fail_closed": false},
      "expected_source_hashes": {}
    }
  ],
  "structural_detectors": [
    "cross_module_private_references",
    "private_helper_reexports",
    "tests_private_production_internals",
    "import_cycles",
    "weak_public_contracts",
    "module_dependency_fanout",
    "production_module_size_function_count",
    "large_typed_god_modules",
    "touched_function_complexity",
    "gate_scope_or_threshold_weakening",
    "duplicate_compatibility_surfaces",
    "publicized_private_helper_renames"
  ],
  "detector_policies": {
    "cross_module_private_references": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {}},
    "private_helper_reexports": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {}},
    "tests_private_production_internals": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {}},
    "import_cycles": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {}},
    "weak_public_contracts": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {}},
    "module_dependency_fanout": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {"max_imports": 30}},
    "production_module_size_function_count": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {"max_lines": 1000, "max_functions": 150}},
    "large_typed_god_modules": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {"max_lines": 1000, "max_functions": 150}},
    "touched_function_complexity": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {"max_complexity": 10}},
    "gate_scope_or_threshold_weakening": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {}},
    "duplicate_compatibility_surfaces": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {}},
    "publicized_private_helper_renames": {"required": true, "blocking": true, "fail_on_unknown": true, "thresholds": {}}
  },
  "gate_contract": {
    "required_files": ["pyproject.toml", ".github/workflows", ".github/governance/supportability.yml"],
    "approved_reusable_workflows": [
      "markheck-solutions/governance/.github/workflows/supportability-gate.yml"
    ],
    "required_commands": [
      "python -m ruff check governance_eval tests",
      "python -m ruff format --check governance_eval tests",
      "python -m mypy governance_eval",
      "python -m ruff check --select C901 governance_eval tests",
      "python -m governance_eval architecture-gate --config .github/governance/supportability.yml --target-repo . --base-sha $TARGET_BASE_SHA --head-sha $TARGET_HEAD_SHA --output-dir artifacts/supportability/architecture",
      "python -m unittest discover -s tests -p test_*.py",
      "python -m build",
      "python -m pip check"
    ],
    "governed_roots": ["governance_eval", "tests"],
    "known_debt": []
  },
  "target_specific_exclusions": [],
  "expected_artifact_fields": [
    "governance_repository_url",
    "governance_evaluator_git_sha",
    "governance_target_pack_hash",
    "schema_hashes",
    "dependency_lock_hash",
    "target_repository_url",
    "target_pr_number",
    "target_base_sha",
    "target_head_sha",
    "revision_mode",
    "commands",
    "operating_system",
    "runner_os",
    "python_version",
    "review_gate",
    "github_review_state",
    "applicable_behavior_case_count",
    "case_counts",
    "setup_results",
    "behavior_results",
    "structural_metrics_before",
    "structural_metrics_after",
    "structural_delta",
    "structural_measurements",
    "acceptance_errors",
    "deterministic_evidence_hash",
    "artifact_content_hash",
    "enforcement_mode"
  ],
  "supported_operating_systems": ["ubuntu-latest", "windows"],
  "runtime_prerequisites": ["git", "python>=3.12"]
}
