{
  "type": "object",
    "required": [
        "schema_version",
        "receipt_kind",
        "plan_id",
        "checkout_receipt_id",
        "evaluation_role",
        "repository",
        "pull_request",
        "target",
        "policy",
        "caller_workflow",
        "evaluator",
        "run",
        "inputs",
        "runtime",
        "step"
    ],
    "properties": {
        "schema_version": {
            "const": "2.0"
        },
        "receipt_kind": {
            "const": "execution_plan.v2"
        },
        "plan_id": {
            "$ref": "#/$defs/sha256"
        },
        "checkout_receipt_id": {
            "$ref": "#/$defs/sha256"
        },
        "evaluation_role": {
            "type": "string",
            "enum": [
                "BASELINE",
                "CANDIDATE"
            ]
        },
        "repository": {
            "type": "object",
            "required": [
                "id",
                "full_name"
            ],
            "properties": {
                "id": {
                    "$ref": "#/$defs/positive_id"
                },
                "full_name": {
                    "$ref": "#/$defs/repository_name"
                }
            },
            "additionalProperties": false
        },
        "pull_request": {
            "$ref": "#/$defs/pull_request"
        },
        "target": {
            "$ref": "#/$defs/target"
        },
        "policy": {
            "$ref": "#/$defs/policy"
        },
        "caller_workflow": {
            "$ref": "#/$defs/workflow"
        },
        "evaluator": {
            "type": "object",
            "required": [
                "repository_id",
                "repository_full_name",
                "commit_sha",
                "tree_sha",
                "workflow"
            ],
            "properties": {
                "repository_id": {
                    "$ref": "#/$defs/positive_id"
                },
                "repository_full_name": {
                    "$ref": "#/$defs/repository_name"
                },
                "commit_sha": {
                    "$ref": "#/$defs/sha"
                },
                "tree_sha": {
                    "$ref": "#/$defs/sha"
                },
                "workflow": {
                    "$ref": "#/$defs/workflow"
                }
            },
            "additionalProperties": false
        },
        "run": {
            "$ref": "#/$defs/run"
        },
        "inputs": {
            "type": "object",
            "required": [
                "scope_manifest_id",
                "toolchain",
                "artifacts"
            ],
            "properties": {
                "scope_manifest_id": {
                    "$ref": "#/$defs/sha256"
                },
                "toolchain": {
                    "type": [
                        "object",
                        "null"
                    ],
                    "required": [
                        "bundle_id",
                        "manifest_sha256",
                        "lock_sha256",
                        "image"
                    ],
                    "properties": {
                        "bundle_id": {
                            "$ref": "#/$defs/sha256"
                        },
                        "manifest_sha256": {
                            "$ref": "#/$defs/sha256"
                        },
                        "lock_sha256": {
                            "$ref": "#/$defs/sha256"
                        },
                        "image": {
                            "$ref": "#/$defs/image_reference"
                        }
                    },
                    "additionalProperties": false
                },
                "artifacts": {
                    "type": "array",
                    "maxItems": 1,
                    "items": {
                        "$ref": "#/$defs/input_artifact"
                    }
                }
            },
            "additionalProperties": false
        },
        "runtime": {
            "oneOf": [
                {
                    "$ref": "#/$defs/docker_runtime"
                },
                {
                    "$ref": "#/$defs/trusted_runtime"
                }
            ]
        },
        "step": {
            "$ref": "#/$defs/step"
        }
    },
    "additionalProperties": false,
    "$defs": {
        "positive_id": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
        },
        "sha": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
        },
        "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
        },
        "repository_name": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "timestamp": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,6})?Z$"
        },
        "image_reference": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._/-]*@sha256:[0-9a-f]{64}$"
        },
        "pull_ref": {
            "type": "object",
            "required": [
                "repository_id",
                "repository_full_name",
                "ref",
                "commit_sha",
                "tree_sha"
            ],
            "properties": {
                "repository_id": {
                    "$ref": "#/$defs/positive_id"
                },
                "repository_full_name": {
                    "$ref": "#/$defs/repository_name"
                },
                "ref": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255
                },
                "commit_sha": {
                    "$ref": "#/$defs/sha"
                },
                "tree_sha": {
                    "$ref": "#/$defs/sha"
                }
            },
            "additionalProperties": false
        },
        "pull_request": {
            "type": "object",
            "required": [
                "number",
                "api_url",
                "html_url",
                "base",
                "head"
            ],
            "properties": {
                "number": {
                    "$ref": "#/$defs/positive_id"
                },
                "api_url": {
                    "type": "string",
                    "pattern": "^https://api\\.github\\.com/repos/"
                },
                "html_url": {
                    "type": "string",
                    "pattern": "^https://github\\.com/"
                },
                "base": {
                    "$ref": "#/$defs/pull_ref"
                },
                "head": {
                    "$ref": "#/$defs/pull_ref"
                }
            },
            "additionalProperties": false
        },
        "target": {
            "type": "object",
            "required": [
                "commit_sha",
                "tree_sha",
                "diff_base_commit_sha",
                "diff_base_tree_sha"
            ],
            "properties": {
                "commit_sha": {
                    "$ref": "#/$defs/sha"
                },
                "tree_sha": {
                    "$ref": "#/$defs/sha"
                },
                "diff_base_commit_sha": {
                    "$ref": "#/$defs/sha"
                },
                "diff_base_tree_sha": {
                    "$ref": "#/$defs/sha"
                }
            },
            "additionalProperties": false
        },
        "policy_file": {
            "type": "object",
            "required": [
                "path",
                "git_blob_sha",
                "content_sha256"
            ],
            "properties": {
                "path": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 512
                },
                "git_blob_sha": {
                    "$ref": "#/$defs/sha"
                },
                "content_sha256": {
                    "$ref": "#/$defs/sha256"
                }
            },
            "additionalProperties": false
        },
        "policy": {
            "type": "object",
        "required": [
            "source",
            "commit_sha",
            "tree_sha",
            "config",
            "standard",
            "execution_profile"
        ],
            "properties": {
                "source": {
                    "type": "string",
                    "enum": [
                        "BASE",
                        "HEAD"
                    ]
                },
                "commit_sha": {
                    "$ref": "#/$defs/sha"
                },
                "tree_sha": {
                    "$ref": "#/$defs/sha"
                },
                "config": {
                    "$ref": "#/$defs/policy_file"
                },
            "standard": {
                "$ref": "#/$defs/policy_file"
            },
            "execution_profile": {
                "$ref": "#/$defs/execution_profile"
            }
            },
            "additionalProperties": false
        },
    "execution_profile": {
        "type": "object",
        "required": [
            "mode",
            "source_schema_version",
            "effective_schema_version",
            "profile_id"
        ],
        "properties": {
            "mode": {
                "type": "string",
                "enum": [
                    "legacy_v1_exact",
                    "typed_v2"
                ]
            },
            "source_schema_version": {
                "type": "string",
                "enum": [
                    "1.0",
                    "2.0"
                ]
            },
            "effective_schema_version": {
                "const": "2.0"
            },
            "profile_id": {
                "const": "8bed910deec331868a94c7dc7c835c919b8cf1799cd817152452cae3bdf03316"
            }
        },
        "additionalProperties": false
    },
    "workflow": {
            "type": "object",
            "required": [
                "repository_id",
                "repository_full_name",
                "path",
                "workflow_ref",
                "commit_sha",
                "tree_sha",
                "git_blob_sha",
                "content_sha256"
            ],
            "properties": {
                "repository_id": {
                    "$ref": "#/$defs/positive_id"
                },
                "repository_full_name": {
                    "$ref": "#/$defs/repository_name"
                },
                "path": {
                    "type": "string",
                    "pattern": "^\\.github/workflows/[A-Za-z0-9_.-]+\\.ya?ml$"
                },
                "workflow_ref": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1024
                },
                "commit_sha": {
                    "$ref": "#/$defs/sha"
                },
                "tree_sha": {
                    "$ref": "#/$defs/sha"
                },
                "git_blob_sha": {
                    "$ref": "#/$defs/sha"
                },
                "content_sha256": {
                    "$ref": "#/$defs/sha256"
                }
            },
            "additionalProperties": false
        },
        "run": {
            "type": "object",
            "required": [
                "id",
                "attempt",
                "api_url",
                "event",
                "action",
                "artifact_name",
                "observed_at"
            ],
            "properties": {
                "id": {
                    "$ref": "#/$defs/positive_id"
                },
                "attempt": {
                    "$ref": "#/$defs/positive_id"
                },
                "api_url": {
                    "type": "string",
                    "pattern": "^https://api\\.github\\.com/repos/"
                },
                "event": {
                    "const": "pull_request_target"
                },
                "action": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80
                },
                "artifact_name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255
                },
                "observed_at": {
                    "$ref": "#/$defs/timestamp"
                }
            },
            "additionalProperties": false
        },
        "executable": {
            "type": "object",
            "required": [
                "path",
                "sha256",
                "version"
            ],
            "properties": {
                "path": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1024
                },
                "sha256": {
                    "$ref": "#/$defs/sha256"
                },
                "version": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 160
                }
            },
            "additionalProperties": false
        },
        "python_runtime": {
            "type": "object",
            "required": [
                "path",
                "sha256",
                "implementation",
                "version",
                "cache_tag"
            ],
            "properties": {
                "path": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1024
                },
                "sha256": {
                    "$ref": "#/$defs/sha256"
                },
                "implementation": {
                    "const": "CPython"
                },
                "version": {
                    "type": "string",
                    "pattern": "^3\\.12\\.[0-9]+$"
                },
                "cache_tag": {
                    "const": "cpython-312"
                }
            },
            "additionalProperties": false
        },
        "docker_identity": {
            "type": "object",
            "required": [
                "path",
                "sha256",
                "host",
                "client_version",
                "server_version",
                "server_api_version",
                "os",
                "architecture"
            ],
            "properties": {
                "path": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 1024
                },
                "sha256": {
                    "$ref": "#/$defs/sha256"
                },
                "host": {
                    "type": "string",
                    "enum": [
                        "unix:///var/run/docker.sock",
                        "npipe:////./pipe/docker_engine"
                    ]
                },
                "client_version": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80
                },
                "server_version": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80
                },
                "server_api_version": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80
                },
                "os": {
                    "const": "linux"
                },
                "architecture": {
                    "type": "string",
                    "enum": [
                        "amd64",
                        "x86_64"
                    ]
                }
            },
            "additionalProperties": false
        },
        "toolchain": {
            "type": "object",
            "required": [
                "bundle_id",
                "manifest_sha256",
                "lock_sha256",
                "image"
            ],
            "properties": {
                "bundle_id": {
                    "$ref": "#/$defs/sha256"
                },
                "manifest_sha256": {
                    "$ref": "#/$defs/sha256"
                },
                "lock_sha256": {
                    "$ref": "#/$defs/sha256"
                },
                "image": {
                    "$ref": "#/$defs/image_reference"
                }
            },
            "additionalProperties": false
        },
        "docker_runtime": {
            "type": "object",
            "required": [
                "kind",
                "runtime_id",
                "policy_id",
                "image",
                "toolchain",
                "pull",
                "network",
                "user",
                "read_only_root",
                "cap_drop",
                "no_new_privileges",
                "pids_limit",
                "memory_bytes",
                "memory_swap_bytes",
                "cpus",
                "docker"
            ],
            "properties": {
                "kind": {
                    "const": "docker"
                },
                "runtime_id": {
                    "const": "docker.python-toolchain.v2"
                },
                "policy_id": {
                    "const": "docker.lockdown.v2"
                },
                "image": {
                    "type": "object",
                    "required": [
                        "reference",
                        "image_id"
                    ],
                    "properties": {
                        "reference": {
                            "$ref": "#/$defs/image_reference"
                        },
                        "image_id": {
                            "type": "string",
                            "pattern": "^sha256:[0-9a-f]{64}$"
                        }
                    },
                    "additionalProperties": false
                },
                "toolchain": {
                    "type": [
                        "object",
                        "null"
                    ],
                    "required": [
                        "bundle_id",
                        "manifest_sha256",
                        "lock_sha256",
                        "image"
                    ],
                    "properties": {
                        "bundle_id": {
                            "$ref": "#/$defs/sha256"
                        },
                        "manifest_sha256": {
                            "$ref": "#/$defs/sha256"
                        },
                        "lock_sha256": {
                            "$ref": "#/$defs/sha256"
                        },
                        "image": {
                            "$ref": "#/$defs/image_reference"
                        }
                    },
                    "additionalProperties": false
                },
                "pull": {
                    "const": "never"
                },
                "network": {
                    "const": "none"
                },
                "user": {
                    "const": "65532:65532"
                },
                "read_only_root": {
                    "const": true
                },
                "cap_drop": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 1,
                    "items": {
                        "const": "ALL"
                    }
                },
                "no_new_privileges": {
                    "const": true
                },
                "pids_limit": {
                    "const": 128
                },
                "memory_bytes": {
                    "const": 536870912
                },
                "memory_swap_bytes": {
                    "const": 536870912
                },
                "cpus": {
                    "const": "1.0"
                },
                "docker": {
                    "$ref": "#/$defs/docker_identity"
                }
            },
            "additionalProperties": false
        },
        "trusted_runtime": {
            "type": "object",
            "required": [
                "kind",
                "runtime_id",
                "python",
                "git"
            ],
            "properties": {
                "kind": {
                    "const": "trusted_judge"
                },
                "runtime_id": {
                    "const": "trusted.python-git.v1"
                },
                "python": {
                    "$ref": "#/$defs/python_runtime"
                },
                "git": {
                    "$ref": "#/$defs/executable"
                }
            },
            "additionalProperties": false
        },
        "input_artifact": {
            "type": "object",
            "required": [
                "kind",
                "name",
                "filename",
                "sha256",
                "size_bytes",
                "producer_plan_id",
                "producer_artifact_id"
            ],
            "properties": {
                "kind": {
                    "const": "python-wheel"
                },
                "name": {
                    "const": "python-wheel"
                },
                "filename": {
                    "type": "string",
                    "pattern": "^[A-Za-z0-9_.+-]+\\.whl$",
                    "maxLength": 255
                },
                "sha256": {
                    "$ref": "#/$defs/sha256"
                },
                "size_bytes": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 67108864
                },
                "producer_plan_id": {
                    "$ref": "#/$defs/sha256"
                },
                "producer_artifact_id": {
                    "$ref": "#/$defs/sha256"
                }
            },
            "additionalProperties": false
        },
        "step": {
            "type": "object",
            "required": [
                "capability",
                "adapter_id",
                "execution",
                "scope_rule_id",
                "mount_profile",
                "working_directory",
                "argv",
                "operation_id",
                "timeout_seconds",
                "total_timeout_seconds",
                "output_limit_bytes",
                "expected_artifacts"
            ],
            "properties": {
                "capability": {
                    "type": "string",
                    "enum": [
                        "lint",
                        "format_check",
                        "typecheck",
                        "complexity",
                        "architecture",
                        "tests",
                        "build",
                        "package_audit",
                        "benchmark",
                        "diff_integrity"
                    ]
                },
                "adapter_id": {
                    "type": "string",
                    "enum": [
                        "python.ruff-check.v1",
                        "python.ruff-format-check.v1",
                        "python.mypy.v1",
                        "python.ruff-c901.v1",
                        "governance.architecture.v1",
                        "python.unittest.v1",
                        "python.pip-wheel-no-deps.v1",
                        "python.package-audit-isolated.v1",
                        "governance.phase1-benchmark.v1",
                        "git.diff-check.v1"
                    ]
                },
                "execution": {
                    "type": "string",
                    "enum": [
                        "docker",
                        "trusted_judge"
                    ]
                },
                "scope_rule_id": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80
                },
                "mount_profile": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 80
                },
                "working_directory": {
                    "type": "string",
                    "pattern": "^/",
                    "maxLength": 255
                },
                "argv": {
                    "type": [
                        "array",
                        "null"
                    ],
                    "maxItems": 20064,
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 1024
                    }
                },
                "operation_id": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "maxLength": 160
                },
                "timeout_seconds": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 120
                },
                "total_timeout_seconds": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 600
                },
                "output_limit_bytes": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 262144
                },
                "expected_artifacts": {
                    "type": "array",
                    "maxItems": 8,
                    "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 80
                    }
                }
            },
            "additionalProperties": false
        }
    }
}
